<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Copy this file to Secrets.plist (same folder) and fill in your Supabase values.
  Secrets.plist is git-ignored. Find these in your Supabase project:
  Settings -> API -> Project URL and the "anon / public" key.
-->
<plist version="1.0">
<dict>
    <key>SUPABASE_URL</key>
    <string>https://YOUR-PROJECT-ref.supabase.co</string>
    <key>SUPABASE_ANON_KEY</key>
    <string>YOUR-ANON-PUBLIC-KEY</string>
</dict>
</plist>
